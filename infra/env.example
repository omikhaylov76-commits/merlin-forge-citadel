# Шаблон окружения. Реальные значения — только в env Railway / локальном .env (в git НЕ попадает).

# — ядро (core) —
DATABASE_URL=                 # Postgres платформы; единственный владелец — core
MF_MASTER_PUBLIC_KEY=         # публичная половина конверта: ядро ШИФРУЕТ ключ биржи на приёме (ADR-0010).
                              #   Прочитать секрет обратно ядро НЕ может — это в env ядра безопасно.

# — оркестратор (руки платформы) —
MF_MASTER_PRIVATE_KEY=        # приватная половина: расшифровка при деплое инстанса. ТОЛЬКО у оркестратора!
RAILWAY_API_TOKEN=            # драйвер Railway; только у оркестратора

# — алерты (outbox → Telegram) —
TELEGRAM_BOT_TOKEN=
TELEGRAM_OPERATOR_CHAT=
